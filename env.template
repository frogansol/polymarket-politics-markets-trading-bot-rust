# Required: EOA private key (Polymarket wallet)
PRIVATE_KEY=

# CLOB and Gamma (defaults shown)
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
GAMMA_HOST=https://gamma-api.polymarket.com

# Per-outcome prices (0 < price < 1)
TARGET_PRICE_UP=0.45
SELL_PRICE_UP=0.55
TARGET_PRICE_DOWN=0.45
SELL_PRICE_DOWN=0.55

# Shares per side (min 5); USD per side ≈ ORDER_AMOUNT_TOKEN × TARGET_PRICE_*
ORDER_AMOUNT_TOKEN=5
CHECK_INTERVAL=10000
SELL_DELAY_MS=10000

# Optional
# MIN_SECONDS_TO_ENTER=20
# MIN_SECONDS_BEFORE_EXPIRY=299
# EXIT_BEFORE_CLOSE_SECONDS=20
# AGGRESSIVE_EXIT_PRICE=0.4

# continuous = loop forever; once = trade one market duration then exit
TRADING_MODE=continuous

# Optional: append logs to file; per-market logs go to logs/markets/<marketKey>.log
# LOG_FILE=logs/trading.log

# Optional: Gnosis Safe proxy (funder) for CLOB signatureType=2
FUNDER_ADDRESS=
